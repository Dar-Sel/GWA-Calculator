subjects = [
    "Mathematics 1",
    "Integrated Science",
    "English 1",
    "Filipino 1",
    "Social Science 1",
    "Computer Science 1",
    "AdTech 1 (Arts, Design, Technology)",
    "P.E.H.M (Physical Education, Health, Music)"
]
subject_grades = [0, 0, 0, 0, 0, 0, 0, 0]
original_subject_grades = [0, 0, 0, 0, 0, 0, 0, 0]
projected_subject_grades = [0, 0, 0, 0, 0, 0, 0, 0]
sum_grades = 0
projected_sum_grades = 0

def GwaCalculation(grade, index):
    if index < 2:
        return grade * 1.7
    elif index == 2:
        return grade * 1.3
    else:
        return grade * 1

def GwaDescription(gwa):
    if 1.00 <= gwa < 1.25:
        return "Excellent and Included in the Director's List"
    elif 1.25 <= gwa <= 1.50:
        return "Very Good and Included in the Director's List"
    elif 1.50 < gwa < 2.25:
        return "Good"
    elif 2.25 <= gwa <= 2.50:
        return "Satisfactory"
    elif 2.50 < gwa <= 3.00:
        return "Fair"
    elif 3.00 < gwa <= 4.00:
        return "Failed on Condition"
    else:
        return "Failing :("

def GwaFormatting(grades):
    return int(grades / 9.7 * 100) / 100

def LowestAndHighestGwa(label, target_grade, grade, subjects):
    print(f"{label}: {target_grade:.2f}")
    print("In The Following Subject/s: ")
    for counter in range(len(grade)):
        if grade[counter] == target_grade:
            print(f"    {subjects[counter]}")

def ErrorMessage():
    return "\nInvalid Input - Please Try Again\n"

for counter in range(len(subjects)):
    while True:
        try:
            subject_grades[counter] = float(
                input("Input the grade for " + subjects[counter] + ": ")
            )
            if subject_grades[counter] < 1 or subject_grades[counter] > 5:
                print(ErrorMessage())
            else:
                break
        except ValueError:
            print(ErrorMessage())

    original_subject_grades[counter] = subject_grades[counter]
    projected_subject_grades[counter] = subject_grades[counter]
    sum_grades += GwaCalculation(subject_grades[counter], counter)
sum_grades = GwaFormatting(sum_grades)

print(
    "\n----- GWA SUMMARY -----\n",
    f"With a GWA of: {sum_grades:.2f}\n",
    f"You are: {GwaDescription(sum_grades)}\n"
)
LowestAndHighestGwa("Highest Grade", min(original_subject_grades), original_subject_grades, subjects)
LowestAndHighestGwa("Lowest Grade", max(original_subject_grades), original_subject_grades, subjects)

print("----- PROJECTED GRADES -----")
lowest_index = original_subject_grades.index(max(original_subject_grades))

while True:
    try:
        increment = float(input(f"Target point increase for {subjects[lowest_index]}: "))
        if (
            increment < 0
            or original_subject_grades[lowest_index] - increment < 1.00
        ):
            print(ErrorMessage())
        else:
            break
    except ValueError:
        print(ErrorMessage())

projected_subject_grades[lowest_index] -= increment
new_grade = projected_subject_grades[lowest_index]

for counter in range(len(projected_subject_grades)):
    projected_sum_grades += GwaCalculation(projected_subject_grades[counter], counter)

projected_sum_grades = GwaFormatting(projected_sum_grades)

print(
    f"Projected Result: Raising {subjects[lowest_index]} by {increment:.2f} points to {new_grade:.2f},\n" 
    f"    bringing your GWA to {projected_sum_grades:.2f}."
)

if GwaDescription(sum_grades) == GwaDescription(projected_sum_grades):
    print(f"However, your overall standing would remain: {GwaDescription(projected_sum_grades)}")
else:
    print(f"This would change your overall standing to: {GwaDescription(projected_sum_grades)}")
